APP_NAME=KSeF Backend
APP_ENV=local
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ksef_backend
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
CONTRACTOR_CACHE_TTL_DAYS=7
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
KSEF_ENVIRONMENT=test
REGON_ENVIRONMENT=production
REGON_API_KEY=change-me
REGON_WSDL_TEST=https://wyszukiwarkaregontest.stat.gov.pl/wsBIR/UslugaBIRzewnPubl.svc?wsdl
REGON_WSDL_PRODUCTION=https://wyszukiwarkaregon.stat.gov.pl/wsBIR/UslugaBIRzewnPubl.svc?wsdl
REQUEST_TIMEOUT_SECONDS=15

