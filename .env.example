# ─── Środowisko ───────────────────────────────────────────────────────────────
APP_NAME=Imperium Faktur G
APP_ENV=production
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ─── Baza danych ──────────────────────────────────────────────────────────────
# Hostname "db" = nazwa usługi w docker-compose
DATABASE_URL=postgresql+psycopg://postgres:ZMIEN_HASLO@db:5432/ksef_backend
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
# Dane kontenera PostgreSQL (muszą być spójne z DATABASE_URL powyżej)
POSTGRES_DB=ksef_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ZMIEN_HASLO

# ─── Bezpieczeństwo ───────────────────────────────────────────────────────────
# Wymagane w produkcji: min. 32 znaki, losowy ciąg
# Generuj: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Administrator bootstrap (opcjonalne — usuń po pierwszym starcie) ──────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# ─── Sprzedawca (dane na fakturze) ────────────────────────────────────────────
SELLER_NIP=
SELLER_NAME=
SELLER_STREET=
SELLER_BUILDING_NO=
SELLER_APARTMENT_NO=
SELLER_POSTAL_CODE=
SELLER_CITY=
SELLER_COUNTRY=PL

# ─── KSeF ─────────────────────────────────────────────────────────────────────
KSEF_ENVIRONMENT=test
KSEF_AUTH_TOKEN=
KSEF_TIMEOUT_SECONDS=30

# ─── REGON ────────────────────────────────────────────────────────────────────
REGON_ENVIRONMENT=production
REGON_API_KEY=
REGON_WSDL_TEST=https://wyszukiwarkaregontest.stat.gov.pl/wsBIR/UslugaBIRzewnPubl.svc?wsdl
REGON_WSDL_PRODUCTION=https://wyszukiwarkaregon.stat.gov.pl/wsBIR/UslugaBIRzewnPubl.svc?wsdl
REQUEST_TIMEOUT_SECONDS=15

# ─── Kontrahenci ──────────────────────────────────────────────────────────────
CONTRACTOR_CACHE_TTL_DAYS=7

# ─── Monitoring (opcjonalne) ──────────────────────────────────────────────────
ALERT_WEBHOOK_URL=

# ─── Feature flags ────────────────────────────────────────────────────────────
ENABLE_KSEF=true
ENABLE_WAREHOUSE=true
ENABLE_PAYMENTS=true

