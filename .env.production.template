# .env.production — DS723+ (produkcja)
# NIGDY nie commitować tego pliku do repozytorium!
# Skopiuj na serwer przez: scp .env.production user@100.87.84.118:/volume1/docker/ifg/
# Plik musi być w katalogu nadrzędnym względem docker/ (czyli obok docker-compose.prod.yml)

# ── Aplikacja ──────────────────────────────────────────────────
APP_NAME=IFG Faktury
APP_ENV=production
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ── Baza danych ────────────────────────────────────────────────
# Adres wewnętrzny Docker (nazwa serwisu)
DATABASE_URL=postgresql+psycopg2://postgres:ZMIEN_HASLO_DB@db:5432/ksef_backend
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
POSTGRES_DB=ksef_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ZMIEN_HASLO_DB

# ── JWT ────────────────────────────────────────────────────────
# Wygeneruj: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=ZMIEN_NA_LOSOWY_KLUCZ_MIN_32_ZNAKI
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Konto admina (tworzone przy 1. starcie) ────────────────────
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ZMIEN_HASLO_ADMINA

# ── Dane sprzedawcy ────────────────────────────────────────────
SELLER_NIP=
SELLER_NAME=
SELLER_STREET=
SELLER_BUILDING_NO=
SELLER_APARTMENT_NO=
SELLER_POSTAL_CODE=
SELLER_CITY=
SELLER_COUNTRY=PL

# ── KSeF ───────────────────────────────────────────────────────
# Środowisko: "prod" = produkcja KSeF, "test" = środowisko testowe MF
KSEF_ENVIRONMENT=prod

# Token autoryzacyjny KSeF (z certyfikatu kwalifikowanego lub pieczęci)
# Instrukcja pozyskania: docs/klucze_ksef.md
KSEF_AUTH_TOKEN=

# Ścieżka do katalogu z kluczami KSeF wewnątrz kontenera
# (zmapowany jako wolumen ksef_keys:/app/ksef_keys)
KSEF_KEYS_DIR=/app/ksef_keys

KSEF_TIMEOUT_SECONDS=30

# ── REGON ──────────────────────────────────────────────────────
REGON_ENVIRONMENT=production
REGON_API_KEY=

# ── Limity ─────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=15
CONTRACTOR_CACHE_TTL_DAYS=7

# ── Alerty (opcjonalne webhook np. Discord/Slack) ──────────────
ALERT_WEBHOOK_URL=

# ── Feature flags ──────────────────────────────────────────────
ENABLE_KSEF=true
ENABLE_WAREHOUSE=true
ENABLE_PAYMENTS=true
